  "keyFeatures": [
    "Save file editing for all Pokémon generations (1-9)",
    "Pokémon entity creation and modification with format-specific implementations",
    "Comprehensive legality analysis and validation system",
    "Pokémon Showdown text format import/export",
    "Mystery Gift file support and conversion",
    "Cross-generation format conversion",
    "GameCube memory card save file support",
    "Battle video and team import capabilities"
  ],
  "publicApiSurface": [
    "PKM - Base class for all Pokémon entity formats",
    "SaveFile - Base class for save file implementations",
    "LegalityAnalysis - Validates Pokémon legality",
    "ShowdownSet - Import/export Showdown format",
    "MysteryGift - Mystery gift event data",
    "PK1-PK9 - Generation-specific Pokémon formats",
    "SAV1-SAV9 - Generation-specific save file formats",
    "BallApplicator - Apply Poké Ball properties",
    "MoveApplicator - Apply move data",
    "RibbonApplicator - Apply ribbon data",
    "EntityConverter - Convert between formats",
    "Legal - Legality checking utilities",
    "PersonalTable - Species stat and ability data",
    "GameInfo - Game version and string data"
  ]
